#!/usr/bin/env bash
#MISE description="Wake an agent into a session via zmx"
#USAGE arg "<session_id>" help="Session ID to wake into (prefix match supported)"
#USAGE flag "--context <context>" help="Inject a context message into the session file before launching"
#USAGE flag "--context-file <context_file>" help="File containing context message to inject"
#USAGE flag "--name <name>" help="Shell session name — becomes CHAT_IDENTITY (default: session ID prefix)"
#USAGE flag "--message <message>" help="Message to pass to the agent"
#USAGE flag "--meta <meta>" var=#true help="Metadata for the wake event (repeatable, dotted paths or jq expressions)"

set -euo pipefail

SESSION_ID="${usage_session_id:-}"
CONTEXT="${usage_context:-}"
WAKE_META_RAW="${usage_meta:-}"
CONTEXT_FILE="${usage_context_file:-}"
SHELL_NAME="${usage_name:-}"
MESSAGE="${usage_message:-}"

if [ -z "$SESSION_ID" ]; then
  echo "Error: session ID required" >&2
  echo "Usage: sessions wake <session_id> [--name <shell-name>] [--message '...']" >&2
  exit 1
fi

# --- Dependencies ---

if ! command -v shell >/dev/null 2>&1; then
  echo "Error: shell is required (shiv install shell)" >&2
  exit 1
fi

command -v jq >/dev/null 2>&1 || { echo "Error: jq is required" >&2; exit 1; }

# AGENT_HARNESS_HEADLESS is a multi-word command (e.g., "shimmer agent --headless").
# Split into array for proper argument handling.
HARNESS_HEADLESS="${AGENT_HARNESS_HEADLESS:-}"
if [ -z "$HARNESS_HEADLESS" ]; then
  echo "Error: AGENT_HARNESS_HEADLESS not set" >&2
  echo "Set it in your shell config, e.g.: export AGENT_HARNESS_HEADLESS='shimmer agent --headless'" >&2
  exit 1
fi
read -ra HARNESS_PARTS <<< "$HARNESS_HEADLESS"

# --- Find session file (for context injection and validation) ---

PI_DIR="${PI_DIR:-$HOME/.pi}"
SESSIONS_DIR="$PI_DIR/agent/sessions"

if [ ! -d "$SESSIONS_DIR" ]; then
  echo "Error: No pi sessions directory at $SESSIONS_DIR" >&2
  exit 1
fi

SESSION_FILE=""
MATCHES=()
for PROJECT in "$SESSIONS_DIR"/*/; do
  for JSONL in "$PROJECT"*.jsonl; do
    [ -f "$JSONL" ] || continue
    BASENAME=$(basename "$JSONL" .jsonl)
    if [[ "$BASENAME" == *_* ]]; then
      UUID_PART="${BASENAME##*_}"
    else
      UUID_PART="$BASENAME"
    fi
    if [[ "$UUID_PART" == "$SESSION_ID"* ]]; then
      MATCHES+=("$JSONL")
    fi
  done
done

case ${#MATCHES[@]} in
  0)
    echo "Error: No session matching '$SESSION_ID'" >&2
    exit 1
    ;;
  1)
    SESSION_FILE="${MATCHES[0]}"
    ;;
  *)
    echo "Error: Ambiguous session ID '$SESSION_ID', matches:" >&2
    printf '  %s\n' "${MATCHES[@]}" >&2
    exit 1
    ;;
esac

FULL_SESSION_ID=$(head -1 "$SESSION_FILE" | jq -r '.id // empty')
if [ -z "$FULL_SESSION_ID" ]; then
  FULL_SESSION_ID="$SESSION_ID"
fi

# --- Resolve context from file ---

if [ -n "$CONTEXT_FILE" ]; then
  if [ ! -f "$CONTEXT_FILE" ]; then
    echo "Error: context file not found: $CONTEXT_FILE" >&2
    exit 1
  fi
  CONTEXT=$(cat "$CONTEXT_FILE")
fi

# --- Inject wake event ---

LAST_ID=$(tail -1 "$SESSION_FILE" | jq -r '.id // empty')
WAKE_ID=$(uuidgen | tr '[:upper:]' '[:lower:]' | cut -c1-8)
NOW_ISO=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

# Determine shell name early (needed for wake entry)
if [ -z "$SHELL_NAME" ]; then
  SHELL_NAME="${FULL_SESSION_ID:0:8}"
fi

# Build wake meta from --meta flags (same parsing as sessions new)
WAKE_META="{}"
if [ -n "$WAKE_META_RAW" ]; then
  while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    if [[ "$entry" == "{"* ]]; then
      FRAGMENT=$(jq -nc "$entry" 2>&1) || {
        echo "Error: invalid jq expression in --meta: $entry" >&2
        exit 1
      }
      WAKE_META=$(echo "$WAKE_META" "$FRAGMENT" | jq -s '.[0] * .[1]')
    elif [[ "$entry" == *"="* ]]; then
      KEY="${entry%%=*}"
      VALUE="${entry#*=}"
      WAKE_META=$(echo "$WAKE_META" | jq --arg v "$VALUE" "setpath(\"$KEY\" | split(\".\"); \$v)")
    else
      echo "Error: invalid --meta format '$entry'" >&2
      exit 1
    fi
  done < <(printf '%s' "$WAKE_META_RAW" | xargs printf '%s\n')
fi

if [ "$WAKE_META" = "{}" ]; then
  jq -nc \
    --arg id "$WAKE_ID" \
    --arg parent_id "$LAST_ID" \
    --arg ts "$NOW_ISO" \
    --arg shell_name "$SHELL_NAME" \
    --arg agent "${GIT_AUTHOR_NAME:-unknown}" \
    --arg harness "$HARNESS_HEADLESS" \
    '{
      type: "wake",
      id: $id,
      parentId: $parent_id,
      timestamp: $ts,
      shell: $shell_name,
      agent: $agent,
      harness: $harness
    }' >> "$SESSION_FILE"
else
  jq -nc \
    --arg id "$WAKE_ID" \
    --arg parent_id "$LAST_ID" \
    --arg ts "$NOW_ISO" \
    --arg shell_name "$SHELL_NAME" \
    --arg agent "${GIT_AUTHOR_NAME:-unknown}" \
    --arg harness "$HARNESS_HEADLESS" \
    --argjson meta "$WAKE_META" \
    '{
      type: "wake",
      id: $id,
      parentId: $parent_id,
      timestamp: $ts,
      shell: $shell_name,
      agent: $agent,
      harness: $harness,
      meta: $meta
    }' >> "$SESSION_FILE"
fi

# --- Inject context into session file if provided ---

if [ -n "$CONTEXT" ]; then
  LAST_ID="$WAKE_ID"
  MSG_ID=$(uuidgen | tr '[:upper:]' '[:lower:]' | cut -c1-8)

  jq -nc \
    --arg id "$MSG_ID" \
    --arg parent_id "$LAST_ID" \
    --arg ts "$NOW_ISO" \
    --arg content "$CONTEXT" \
    '{
      type: "message",
      id: $id,
      parentId: $parent_id,
      timestamp: $ts,
      message: {
        role: "user",
        content: [{ type: "text", text: $content }]
      }
    }' >> "$SESSION_FILE"
fi

# --- Resolve working directory from session ---

SESSION_CWD=$(sessions meta "${FULL_SESSION_ID:0:8}" --field .cwd 2>/dev/null) || true
if [ -z "$SESSION_CWD" ] || [ ! -d "$SESSION_CWD" ]; then
  echo "Warning: session cwd '$SESSION_CWD' not found, using current directory" >&2
  SESSION_CWD="."
fi

# --- Launch via shell ---

# Build the harness command: cd to session's project dir, then run headless harness
HARNESS_CMD=("${HARNESS_PARTS[@]}" "--session" "$SESSION_FILE")
if [ -n "$MESSAGE" ]; then
  HARNESS_CMD+=("$MESSAGE")
fi

# Launch from the session's working directory so the agent gets the right CLAUDE.md
cd "$SESSION_CWD"
shell run "$SHELL_NAME" "${HARNESS_CMD[@]}"

echo "$FULL_SESSION_ID"
echo "Woke session in shell '$SHELL_NAME'" >&2
echo "Monitor: sessions read ${FULL_SESSION_ID:0:8} --last 10" >&2
echo "Status: shell status $SHELL_NAME" >&2
