#!/usr/bin/env bash
#MISE description="Copy a pi session (with injected copy notice)"
#USAGE flag "--context <context>" help="Optional context for why the fork was created"
#USAGE flag "--name <name>" help="Optional label for the fork"
#USAGE arg "<session_id>" help="Session ID or name to copy"

set -euo pipefail
shopt -s nullglob

# --- Resolve session ID and find source file ---

SESSION_ID="${usage_session_id:-}"

if [ -z "${SESSION_ID:-}" ]; then
  echo "Error: No session ID provided" >&2
  echo "Usage: sessions fork <session_id> [--context '...'] [--name '...']" >&2
  exit 1
fi

command -v jq >/dev/null 2>&1 || { echo "Error: jq is required" >&2; exit 1; }
command -v uuidgen >/dev/null 2>&1 || { echo "Error: uuidgen is required" >&2; exit 1; }

source "$MISE_CONFIG_ROOT/lib/find.sh"
SOURCE_FILE=$(find_session_file "$SESSION_ID") || exit 1

PROJECT_DIR=$(dirname "$SOURCE_FILE")/

# Extract the full session ID from the session header entry
FULL_SESSION_ID=$(head -1 "$SOURCE_FILE" | jq -r '.id // empty')
if [ -z "$FULL_SESSION_ID" ]; then
  echo "Error: Could not read session ID from $SOURCE_FILE" >&2
  exit 1
fi

# --- Fork ---

NEW_ID=$(uuidgen | tr '[:upper:]' '[:lower:]')
NOW_ISO=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")
# Pi filename format: <timestamp>_<uuid>.jsonl (timestamp with dashes instead of colons)
NOW_FILE=$(echo "$NOW_ISO" | sed 's/:/-/g')
NEW_FILE="${PROJECT_DIR}${NOW_FILE}_${NEW_ID}.jsonl"

# Clean up on failure
cleanup() {
  rm -f "$NEW_FILE"
}
trap cleanup ERR

# Copy session JSONL
cp -a "$SOURCE_FILE" "$NEW_FILE"

# --- Rewrite session header with new ID ---

# Replace the first line (session header) with updated id and timestamp
HEADER=$(head -1 "$NEW_FILE" | jq -c \
  --arg id "$NEW_ID" \
  --arg ts "$NOW_ISO" \
  '.id = $id | .timestamp = $ts')

# Write new header + rest of file
{
  echo "$HEADER"
  tail -n +2 "$NEW_FILE"
} > "${NEW_FILE}.tmp"
mv "${NEW_FILE}.tmp" "$NEW_FILE"

# --- Inject fork notification ---

# Get the last entry's id for parentId linking
LAST_ID=$(tail -1 "$NEW_FILE" | jq -r '.id // empty')

NOTICE_ID=$(uuidgen | tr '[:upper:]' '[:lower:]' | cut -c1-8)

# Build the notice content
CONTENT="[Session Fork Notice]
This session was forked from ${FULL_SESSION_ID} at ${NOW_ISO}."
if [ -n "${usage_name:-}" ]; then
  CONTENT="${CONTENT}
Name: ${usage_name}"
fi
if [ -n "${usage_context:-}" ]; then
  CONTENT="${CONTENT}
Context: ${usage_context}"
fi
CONTENT="${CONTENT}
The original session continues independently."

# Append fork notification in pi message format
jq -nc \
  --arg id "$NOTICE_ID" \
  --arg parent_id "$LAST_ID" \
  --arg timestamp "$NOW_ISO" \
  --arg content "$CONTENT" \
  --arg source_session "$FULL_SESSION_ID" \
  '{
    type: "message",
    id: $id,
    parentId: $parent_id,
    timestamp: $timestamp,
    message: {
      role: "user",
      content: [{ type: "text", text: $content }],
      isForkNotification: true,
      sourceSessionId: $source_session
    }
  }' >> "$NEW_FILE"

# --- Output ---

echo "$NEW_ID"
echo "Copied $FULL_SESSION_ID → $NEW_ID" >&2
echo "Source: $(basename "$SOURCE_FILE")" >&2
echo "Copy:   $(basename "$NEW_FILE")" >&2
