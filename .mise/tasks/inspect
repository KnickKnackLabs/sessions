#!/usr/bin/env -S uv run --script
#MISE description="Show forensic metadata for a session (model, context, duration, compaction)"
#USAGE arg "<session_id>" help="Session ID (prefix match supported)"
#USAGE flag "--json" help="Output as JSON"
# /// script
# requires-python = ">=3.10"
# dependencies = ["rich"]
# ///

import json
import os
import sys
from datetime import datetime

sys.path.insert(0, os.environ["MISE_CONFIG_ROOT"] + "/lib")
import parse
from format import (
    STYLE_DIM,
    STYLE_ID,
    STYLE_TOOL,
    console,
    format_date,
    format_duration,
)

session_id = os.environ.get("usage_session_id", "")
if not session_id:
    print("Usage: sessions inspect <session_id>", file=sys.stderr)
    sys.exit(1)

output_json = os.environ.get("usage_json", "") == "true"

filepath = parse.find_session(session_id)
session = parse.load(filepath)
meta = session.metadata()

# --- Extended analysis ---

file_size = os.path.getsize(filepath)

duration_str = format_duration(meta["first_timestamp"], meta["last_timestamp"])

# Models used
models = {}
for e in session.entries:
    if e.get("type") == "message":
        msg = e.get("message", {})
        if msg.get("role") == "assistant":
            m = msg.get("model", "")
            if m:
                models[m] = models.get(m, 0) + 1

# Tools used
tools = {}
for e in session.entries:
    if e.get("type") != "message":
        continue
    msg = e.get("message", {})
    # Count toolCall blocks in assistant messages
    content = msg.get("content", [])
    if isinstance(content, list):
        for block in content:
            if isinstance(block, dict) and block.get("type") == "toolCall":
                name = block.get("name", "?")
                tools[name] = tools.get(name, 0) + 1
    # Also count from toolResult entries (tool name is on the entry)
    if msg.get("role") == "toolResult":
        name = msg.get("toolName", "?")
        # Don't double-count — toolCall already counted it
        pass

# Subagent sessions
subagent_dir = filepath.replace(".jsonl", "")
subagent_count = 0
if os.path.isdir(subagent_dir):
    subagent_count = len([f for f in os.listdir(subagent_dir) if f.endswith(".jsonl")])

# Context usage from user messages
context_snapshots = []
for e in session.entries:
    if e.get("type") != "message":
        continue
    msg = e.get("message", {})
    if msg.get("role") != "user":
        continue
    content = msg.get("content", "")
    text = ""
    if isinstance(content, str):
        text = content
    elif isinstance(content, list):
        text = " ".join(b.get("text", "") for b in content if isinstance(b, dict) and b.get("type") == "text")
    if "Context Usage" in text and "Tokens:" in text:
        for line in text.split("\n"):
            if "Tokens:" in line and "/" in line:
                context_snapshots.append(line.strip().replace("**", ""))

# Entry types
entry_types = {}
for e in session.entries:
    t = e.get("type", "unknown")
    entry_types[t] = entry_types.get(t, 0) + 1

# Compaction
has_summary = "summary" in entry_types

result = {
    **meta,
    "file_size_bytes": file_size,
    "duration": duration_str,
    "models": models,
    "tools": tools,
    "entry_types": entry_types,
    "subagent_sessions": subagent_count,
    "context_snapshots": context_snapshots,
    "has_compaction": has_summary,
}

if output_json:
    print(json.dumps(result, indent=2))
    sys.exit(0)

# --- Rich output ---

from rich.bar import Bar
from rich.table import Table
from rich.text import Text

# Title: slug or truncated ID
title = meta["slug"] or meta["session_id"][:12]
title_text = Text(title, style="bold")
title_text.append(f"  ({meta['session_id'][:8]})", style=STYLE_ID)
console.print()
console.print(title_text)

# Subtitle: project + file size
size_kb = file_size / 1024
size_str = f"{size_kb:.1f} KB" if size_kb < 1024 else f"{size_kb / 1024:.1f} MB"
console.print(Text(f"{meta['project']}  ·  {size_str}", style=STYLE_DIM))

# --- Timing ---
console.print()
console.rule("Timing", style="dim")
console.print()

kv = Table(box=None, show_header=False, padding=(0, 2), expand=False)
kv.add_column("key", style="dim", min_width=10)
kv.add_column("val")
kv.add_row("Started", format_date(meta["first_timestamp"]))
kv.add_row("Ended", format_date(meta["last_timestamp"]))
kv.add_row("Duration", duration_str)
console.print(kv)

# --- Conversation ---
console.print()
console.rule("Conversation", style="dim")
console.print()

total_msgs = meta["user_messages"] + meta["assistant_messages"]

kv2 = Table(box=None, show_header=False, padding=(0, 2), expand=False)
kv2.add_column("key", style="dim", min_width=10)
kv2.add_column("val")
kv2.add_row("Messages", f"{total_msgs} ({meta['user_messages']} user, {meta['assistant_messages']} assistant)")

# Entry type breakdown — show non-message types sorted by frequency
# Friendly names for internal entry types
TYPE_LABELS = {
    "user": "user",
    "assistant": "assistant",
    "progress": "progress",
    "queue-operation": "queue-op",
    "file-history-snapshot": "file-snapshot",
    "last-prompt": "last-prompt",
    "system": "system",
    "summary": "summary",
}
other_types = {k: v for k, v in entry_types.items() if k not in ("user", "assistant")}
if other_types:
    sorted_types = sorted(other_types.items(), key=lambda x: -x[1])
    parts = [f"{v} {TYPE_LABELS.get(k, k)}" for k, v in sorted_types]
    kv2.add_row("Entries", Text.from_markup(
        f"{meta['total_entries']} total  [dim]({' · '.join(parts)})[/dim]"
    ))

kv2.add_row("Compacted", "Yes" if has_summary else "No")

# Models — inline if one real model, expanded if multiple
real_models = {k: v for k, v in models.items() if k != "<synthetic>"}
synthetic_count = models.get("<synthetic>", 0)

if len(real_models) == 1:
    model_name, model_count = next(iter(real_models.items()))
    model_str = model_name
    if synthetic_count:
        model_str += f"  [dim](+{synthetic_count} system-generated)[/dim]"
    kv2.add_row("Model", Text.from_markup(model_str))
elif len(real_models) > 1:
    parts = [f"{name} ({count})" for name, count in sorted(real_models.items(), key=lambda x: -x[1])]
    if synthetic_count:
        parts.append(f"[dim]system-generated ({synthetic_count})[/dim]")
    kv2.add_row("Models", Text.from_markup("  ·  ".join(parts)))
else:
    if synthetic_count:
        kv2.add_row("Model", Text("system-generated only", style="dim"))

if subagent_count:
    kv2.add_row("Subagents", f"{subagent_count} sessions")

console.print(kv2)

# --- Tools ---
if tools:
    console.print()
    console.rule("Tools", style="dim")
    console.print()

    sorted_tools = sorted(tools.items(), key=lambda x: -x[1])
    max_count = sorted_tools[0][1] if sorted_tools else 1

    tool_table = Table(box=None, show_header=False, padding=(0, 2), expand=False)
    tool_table.add_column("name", min_width=20)
    tool_table.add_column("bar", min_width=20)
    tool_table.add_column("count", justify="right", style="bold", min_width=4)

    for name, count in sorted_tools:
        bar = Text()
        filled = int((count / max_count) * 16)
        bar.append("█" * filled, style="cyan")
        bar.append("░" * (16 - filled), style="dim")
        tool_table.add_row(
            Text(name, style=STYLE_TOOL.replace("italic", "").strip()),
            bar,
            str(count),
        )

    console.print(tool_table)

# --- Context ---
if context_snapshots:
    console.print()
    console.rule("Context", style="dim")
    console.print()
    for snap in context_snapshots:
        console.print(f"  {snap}", style="dim")

console.print()
