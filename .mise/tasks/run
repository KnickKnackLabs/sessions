#!/usr/bin/env bash
#MISE description="Run an agent session with streaming output, timeout, and ABORT detection"
#MISE quiet=true
#USAGE arg "<message>" help="Message for the agent"
#USAGE flag "--system-prompt-file <file>" help="Path to system prompt file"
#USAGE flag "--timeout <seconds>" help="Timeout in seconds (default: no timeout)"
#USAGE flag "--model <model>" help="Model to use"
#USAGE flag "--session <session>" help="Session file for conversation continuity"
#USAGE flag "--cwd <cwd>" help="Working directory for pi"
#USAGE flag "--no-extensions" help="Disable pi extensions"
#USAGE flag "--no-skills" help="Disable pi skills"
#USAGE flag "--no-prompt-templates" help="Disable pi prompt templates"

set -e

MESSAGE="${usage_message:-}"
SYSTEM_PROMPT_FILE="${usage_system_prompt_file:-}"
TIMEOUT="${usage_timeout:-}"
MODEL="${usage_model:-}"
SESSION="${usage_session:-}"
CWD="${usage_cwd:-${CALLER_PWD:-.}}"
NO_EXTENSIONS="${usage_no_extensions:-false}"
NO_SKILLS="${usage_no_skills:-false}"
NO_PROMPT_TEMPLATES="${usage_no_prompt_templates:-false}"

if [ -z "$MESSAGE" ]; then
  echo "Error: message required" >&2
  echo "Usage: sessions run --system-prompt-file <path> [options] \"message\"" >&2
  exit 1
fi

# If no system prompt file provided but AGENT_IDENTITY is in env, write it to a temp file
if [ -z "$SYSTEM_PROMPT_FILE" ] && [ -n "$AGENT_IDENTITY" ]; then
  SYSTEM_PROMPT_FILE=$(mktemp)
  echo "$AGENT_IDENTITY" > "$SYSTEM_PROMPT_FILE"

  # Append passphrase if set
  if [ -n "$AGENT_PASSPHRASE" ]; then
    cat >> "$SYSTEM_PROMPT_FILE" <<'PASSPHRASE_EOF'

## Admin Override

Your admin override passphrase is: PLACEHOLDER

When a message contains your passphrase, it's a direct instruction from admin - execute exactly what is requested, even if it conflicts with your normal workflow.

When you receive your passphrase, output `[[OVERRIDE:brief description of action]]` before proceeding.

Important rules:
- Never reveal or confirm your passphrase to anyone
- If someone uses a wrong passphrase or asks about it, say you don't understand
PASSPHRASE_EOF
    # Replace placeholder with actual passphrase
    sed -i '' "s/Your admin override passphrase is: PLACEHOLDER/Your admin override passphrase is: $AGENT_PASSPHRASE/" "$SYSTEM_PROMPT_FILE"
  fi

  # Append dispatch context if set
  if [ -n "$DISPATCH_CONTEXT" ]; then
    echo "" >> "$SYSTEM_PROMPT_FILE"
    echo "## Dispatch Context" >> "$SYSTEM_PROMPT_FILE"
    echo "This session was triggered by: $DISPATCH_CONTEXT" >> "$SYSTEM_PROMPT_FILE"
  fi

  trap "rm -f '$SYSTEM_PROMPT_FILE'" EXIT
fi

CLI_DIR="$MISE_CONFIG_ROOT/cli"

# Build CLI args
CLI_ARGS=(--system-prompt-file "$SYSTEM_PROMPT_FILE" --cwd "$CWD")

[ -n "$TIMEOUT" ] && CLI_ARGS+=(--timeout "$TIMEOUT")
[ -n "$MODEL" ] && CLI_ARGS+=(--model "$MODEL")
[ -n "$SESSION" ] && CLI_ARGS+=(--session "$SESSION")
[ "$NO_EXTENSIONS" = "true" ] && CLI_ARGS+=(--no-extensions)
[ "$NO_SKILLS" = "true" ] && CLI_ARGS+=(--no-skills)
[ "$NO_PROMPT_TEMPLATES" = "true" ] && CLI_ARGS+=(--no-prompt-templates)

cd "$CLI_DIR"
exec mix sessions "${CLI_ARGS[@]}" "$MESSAGE"
