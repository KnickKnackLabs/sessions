#!/usr/bin/env bash
#MISE description="Fork a Claude Code session"
#USAGE flag "--context <context>" help="Optional context for why the fork was created"
#USAGE flag "--name <name>" help="Optional label for the fork"
#USAGE arg "[session_id]" help="Session ID to fork (default: CLAUDE_CODE_SESSION_ID env var)"

set -euo pipefail
shopt -s nullglob

# --- Resolve session ID ---

SESSION_ID="${usage_session_id:-${CLAUDE_CODE_SESSION_ID:-}}"

if [ -z "${SESSION_ID:-}" ]; then
  echo "Error: No session ID provided and \$CLAUDE_CODE_SESSION_ID is not set" >&2
  exit 1
fi

CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
PROJECTS_DIR="$CLAUDE_DIR/projects"

# --- Validation ---

command -v jq >/dev/null 2>&1 || { echo "Error: jq is required" >&2; exit 1; }
command -v uuidgen >/dev/null 2>&1 || { echo "Error: uuidgen is required" >&2; exit 1; }

if ! [[ "$SESSION_ID" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
  echo "Error: Invalid session ID format (expected UUID)" >&2
  exit 1
fi

if [ ! -d "$PROJECTS_DIR" ]; then
  echo "Error: No Claude projects directory at $PROJECTS_DIR" >&2
  exit 1
fi

# --- Discovery ---

MATCHES=()
for PROJECT in "$PROJECTS_DIR"/*/; do
  if [ -f "${PROJECT}${SESSION_ID}.jsonl" ]; then
    MATCHES+=("$PROJECT")
  fi
done

case ${#MATCHES[@]} in
  0)
    echo "Error: Session $SESSION_ID not found" >&2
    exit 1
    ;;
  1)
    PROJECT_DIR="${MATCHES[0]}"
    ;;
  *)
    echo "Error: Session found in multiple projects (ambiguous):" >&2
    printf '  %s\n' "${MATCHES[@]}" >&2
    exit 1
    ;;
esac

# --- Fork ---

NEW_ID=$(uuidgen | tr '[:upper:]' '[:lower:]')

# Clean up on failure
cleanup() {
  rm -f "${PROJECT_DIR}${NEW_ID}.jsonl"
  rm -rf "${PROJECT_DIR}${NEW_ID}"
}
trap cleanup ERR

# Copy session JSONL
cp -a "${PROJECT_DIR}${SESSION_ID}.jsonl" "${PROJECT_DIR}${NEW_ID}.jsonl"

# Copy session directory if it exists (subagents, tool-results)
if [ -d "${PROJECT_DIR}${SESSION_ID}" ]; then
  cp -a "${PROJECT_DIR}${SESSION_ID}" "${PROJECT_DIR}${NEW_ID}"
fi

# --- Inject fork notification ---

LAST_UUID=$(tail -1 "${PROJECT_DIR}${NEW_ID}.jsonl" | jq -r '.uuid')
NOTICE_UUID=$(uuidgen | tr '[:upper:]' '[:lower:]')
NOW_ISO=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

# Build the notice content with real newlines
CONTENT="[Session Fork Notice]
This session was forked from ${SESSION_ID} at ${NOW_ISO}."
if [ -n "${usage_name:-}" ]; then
  CONTENT="${CONTENT}
Name: ${usage_name}"
fi
if [ -n "${usage_context:-}" ]; then
  CONTENT="${CONTENT}
Context: ${usage_context}"
fi
CONTENT="${CONTENT}
The original session continues independently."

# Construct and append the fork notification record
jq -nc \
  --arg parent_uuid "$LAST_UUID" \
  --arg uuid "$NOTICE_UUID" \
  --arg session_id "$NEW_ID" \
  --arg source_session_id "$SESSION_ID" \
  --arg timestamp "$NOW_ISO" \
  --arg content "$CONTENT" \
  '{
    type: "user",
    userType: "external",
    isSidechain: false,
    isForkNotification: true,
    sourceSessionId: $source_session_id,
    message: {
      role: "user",
      content: $content
    },
    parentUuid: $parent_uuid,
    uuid: $uuid,
    sessionId: $session_id,
    timestamp: $timestamp,
    version: "sessions-fork-1.0"
  }' >> "${PROJECT_DIR}${NEW_ID}.jsonl"

# --- Update sessions index ---
# Disable ERR trap — the fork is valid without an index entry
trap - ERR

INDEX_FILE="${PROJECT_DIR}sessions-index.json"
if [ -f "$INDEX_FILE" ]; then
  SOURCE_ENTRY=$(jq --arg sid "$SESSION_ID" '.entries[] | select(.sessionId == $sid)' "$INDEX_FILE")
  if [ -n "$SOURCE_ENTRY" ]; then
    NOW_MTIME="$(date +%s)000"
    NEW_PATH="${PROJECT_DIR}${NEW_ID}.jsonl"

    jq --arg new_id "$NEW_ID" \
       --arg new_path "$NEW_PATH" \
       --arg now "$NOW_ISO" \
       --argjson mtime "$NOW_MTIME" \
       --arg orig_id "$SESSION_ID" \
       '(.entries[] | select(.sessionId == $orig_id)) as $src |
        .entries += [$src + {
          sessionId: $new_id,
          fullPath: $new_path,
          fileMtime: $mtime,
          created: $now,
          modified: $now
        }]' "$INDEX_FILE" > "${INDEX_FILE}.tmp" \
      && mv "${INDEX_FILE}.tmp" "$INDEX_FILE"
  else
    echo "Note: Source session not in index; fork may not appear in session picker" >&2
  fi
fi

# --- Output ---

echo "$NEW_ID"
echo "Forked $SESSION_ID → $NEW_ID" >&2
echo "Resume with: claude --resume $NEW_ID" >&2
