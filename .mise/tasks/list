#!/usr/bin/env -S uv run --script
#MISE description="List recent sessions with metadata"
#USAGE flag "--limit <n>" default="20" help="Max sessions to show (default: 20)"
#USAGE flag "--project <filter>" help="Filter by project directory (substring match)"
#USAGE flag "--filter <filter>" var=#true help="Filter sessions (type.meta.key=value, supports indexing e.g. wake[0].meta.by=ikma)"
#USAGE flag "--all" help="Include subagent sessions (excluded by default)"
#USAGE flag "--json" help="Output as JSON"
# /// script
# requires-python = ">=3.10"
# dependencies = ["rich"]
# ///

import json
import os
import sys

sys.path.insert(0, os.environ["MISE_CONFIG_ROOT"] + "/lib")
import parse
from format import console, format_duration, format_model, format_relative, make_table

limit = int(os.environ.get("usage_limit", "20"))
project_filter = os.environ.get("usage_project", "")
filter_raw = os.environ.get("usage_filter", "")
include_agents = os.environ.get("usage_all", "") == "true"
output_json = os.environ.get("usage_json", "") == "true"

filters = parse.parse_filters(filter_raw) if filter_raw else []

sessions_dir = parse.discover_sessions_dir()
if not os.path.isdir(sessions_dir):
    print(f"No sessions directory at {sessions_dir}", file=sys.stderr)
    sys.exit(1)

# Collect all JSONL files with their mtime
files = []
for project_dir in os.listdir(sessions_dir):
    project_path = os.path.join(sessions_dir, project_dir)
    if not os.path.isdir(project_path):
        continue
    if project_filter and project_filter not in project_dir:
        continue
    for fname in os.listdir(project_path):
        if not fname.endswith(".jsonl"):
            continue
        # Skip subagent sessions unless --all
        if not include_agents and fname.startswith("agent-"):
            continue
        filepath = os.path.join(project_path, fname)
        mtime = os.path.getmtime(filepath)
        files.append((mtime, filepath))

# Sort by mtime descending
files.sort(key=lambda x: -x[0])

results = []
count = 0
for mtime, filepath in files:
    if count >= limit:
        break
    try:
        session = parse.load(filepath)
        # Skip if filters don't match
        if filters and not parse.session_matches_filters(session, filters):
            continue
        meta = session.metadata()
        # Skip empty/stub sessions — no real assistant interaction
        if not include_agents:
            msgs = meta["user_messages"] + meta["assistant_messages"]
            if msgs == 0 or meta["model"] == "unknown":
                continue
        results.append(meta)
        count += 1
    except Exception:
        continue

if output_json:
    print(json.dumps(results, indent=2))
else:
    if not results:
        print("No sessions found.")
        sys.exit(0)

    table = make_table()
    table.add_column("ID", style="cyan", no_wrap=True)
    table.add_column("Duration", no_wrap=True)
    table.add_column("Active", no_wrap=True)
    table.add_column("Model", style="dim", no_wrap=True)
    table.add_column("Msgs", justify="right", min_width=4)

    for m in results:
        table.add_row(
            m["session_id"][:8],
            format_duration(m["first_timestamp"], m["last_timestamp"]),
            format_relative(m["last_timestamp"]),
            format_model(m["model"]),
            str(m["user_messages"] + m["assistant_messages"]),
        )

    console.print(table)
