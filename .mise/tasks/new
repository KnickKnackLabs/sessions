#!/usr/bin/env bash
#MISE description="Create a new session with optional injected context"
#USAGE arg "[name]" help="Session name (human-readable label, also used for lookup)"
#USAGE flag "--cwd <cwd>" help="Working directory for the session (default: current directory)"
#USAGE flag "--context <context>" help="Initial context message to inject"
#USAGE flag "--context-file <context_file>" help="File containing initial context message"
#USAGE flag "--model <model>" default="claude-sonnet-4-20250514" help="Model to set (default: claude-sonnet-4-20250514)"
#USAGE flag "--meta <meta>" var=#true help="Metadata key=value pairs (repeatable, supports dotted paths e.g. agent.name=ikma)"
#USAGE flag "--harness <harness>" help="Harness adapter to use (default: pi, or value of SESSIONS_DEFAULT_HARNESS)"

set -euo pipefail

NAME="${usage_name:-}"
CWD="${usage_cwd:-}"
CONTEXT="${usage_context:-}"
CONTEXT_FILE="${usage_context_file:-}"
MODEL="${usage_model:-claude-sonnet-4-20250514}"
META_RAW="${usage_meta:-}"
HARNESS_FLAG="${usage_harness:-}"

# Default cwd to current directory
if [ -z "$CWD" ]; then
  CWD="."
fi

# Resolve cwd to absolute path
CWD_ABS=$(cd "$CWD" 2>/dev/null && pwd) || {
  echo "Error: --cwd directory not found: $CWD" >&2
  exit 1
}

# Resolve context from file if provided
if [ -n "$CONTEXT_FILE" ]; then
  if [ ! -f "$CONTEXT_FILE" ]; then
    echo "Error: context file not found: $CONTEXT_FILE" >&2
    exit 1
  fi
  CONTEXT=$(cat "$CONTEXT_FILE")
fi

command -v jq >/dev/null 2>&1 || { echo "Error: jq is required" >&2; exit 1; }
command -v uuidgen >/dev/null 2>&1 || { echo "Error: uuidgen is required" >&2; exit 1; }

# shellcheck source=/dev/null
source "$MISE_CONFIG_ROOT/lib/harness/dispatch.sh"

# Resolve the harness for this new session. No session file yet, so only
# rule 1 (flag), rule 4 (env), and rule 5 (default) can apply.
HARNESS_NAME=$(harness_resolve --flag "$HARNESS_FLAG") || exit 1

# shellcheck source=/dev/null
source "$MISE_CONFIG_ROOT/lib/harness/$HARNESS_NAME.sh"

# --- Generate session ---

SESSION_ID=$(uuidgen | tr '[:upper:]' '[:lower:]')
NOW_ISO=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")
SESSION_FILE=$("harness_${HARNESS_NAME}_session_file_path" "$CWD_ABS" "$SESSION_ID" "$NOW_ISO")

# --- Build meta object from --meta flags ---
#
# Two formats supported:
#   --meta "agent.name=ikma"                          (dotted key=value)
#   --meta '{agent: {name: $ENV.GIT_AUTHOR_NAME}}'    (jq expression)
#
# Detected by first character: { = jq expression, otherwise dotted path.
# Multiple --meta flags are merged left to right.

META_JSON="{}"
if [ -n "$META_RAW" ]; then
  while IFS= read -r entry; do
    [ -z "$entry" ] && continue
    if [[ "$entry" == "{"* ]]; then
      # jq expression — evaluate and merge
      FRAGMENT=$(jq -nc "$entry" 2>&1) || {
        echo "Error: invalid jq expression in --meta: $entry" >&2
        echo "  jq said: $FRAGMENT" >&2
        exit 1
      }
      META_JSON=$(echo "$META_JSON" "$FRAGMENT" | jq -s '.[0] * .[1]')
    elif [[ "$entry" == *"="* ]]; then
      # dotted key=value
      KEY="${entry%%=*}"
      VALUE="${entry#*=}"
      META_JSON=$(echo "$META_JSON" | jq --arg v "$VALUE" "setpath(\"$KEY\" | split(\".\"); \$v)")
    else
      echo "Error: invalid --meta format '$entry'" >&2
      echo "  Expected key=value (e.g., agent.name=ikma) or jq expression (e.g., '{purpose: \"test\"}')" >&2
      exit 1
    fi
  done < <(printf '%s' "$META_RAW" | xargs printf '%s\n')
fi

# --- Session header ---

"harness_${HARNESS_NAME}_header_entry" "$SESSION_ID" "$NOW_ISO" "$CWD_ABS" "$NAME" "$META_JSON" > "$SESSION_FILE"

# Harness declaration entry — records the active harness. Subsequent
# readers (wake, run, read) use `harness_resolve` over this file to
# pick the right adapter.
HARNESS_ENTRY_ID=$(uuidgen | tr '[:upper:]' '[:lower:]' | cut -c1-8)
harness_entry "$HARNESS_ENTRY_ID" "$SESSION_ID" "$NOW_ISO" "$HARNESS_NAME" >> "$SESSION_FILE"

# Model change entry
MC_ID=$(uuidgen | tr '[:upper:]' '[:lower:]' | cut -c1-8)
"harness_${HARNESS_NAME}_model_change_entry" "$MC_ID" "$NOW_ISO" "$MODEL" >> "$SESSION_FILE"

# Inject context as a user message if provided
if [ -n "$CONTEXT" ]; then
  MSG_ID=$(uuidgen | tr '[:upper:]' '[:lower:]' | cut -c1-8)
  "harness_${HARNESS_NAME}_user_message_entry" "$MSG_ID" "$MC_ID" "$NOW_ISO" "$CONTEXT" >> "$SESSION_FILE"
fi

# --- Output ---

echo "$SESSION_ID"
if [ -n "$NAME" ]; then
  echo "Created session '$NAME'" >&2
else
  echo "Created session ${SESSION_ID:0:8}" >&2
fi
echo "cwd: $CWD_ABS" >&2
if [ -n "$CONTEXT" ]; then
  echo "Context: $(echo "$CONTEXT" | head -1 | cut -c1-80)..." >&2
fi
